pipeline {
    agent any

    stages {
        stage('Clone') {
            steps {
                git 'https://github.com/sohailsheikh484-ai/node-jenkins-app.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                bat 'npm test'
            }
        }

        stage('Run') {
            steps {
                bat 'node app.js'
            }
        }
    }
}
